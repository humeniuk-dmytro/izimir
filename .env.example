# Telegram API credentials (https://my.telegram.org)
API_ID=
API_HASH=

# Bot token from @BotFather
BOT_TOKEN=

# Your Telegram user ID (numeric)
OWNER_ID=

# Database path
DB_PATH=data/izimir.db

# Session file names (without extension)
USER_SESSION=data/user_session
BOT_SESSION=data/bot_session

# Scan schedule (comma-separated HH:MM)
SCAN_TIMES=09:00,18:00

# How far back each scan looks, in hours
SCAN_HOURS=24

# Timezone
TIMEZONE=Europe/Istanbul

# How many messages to fetch per group per scan
MESSAGES_LIMIT=500

# Delay between groups in seconds (avoids Telegram flood limits)
RATE_LIMIT_DELAY=2.0

# --- Mini App (optional) ---
# Free HTTPS domain for the Mini App (DuckDNS subdomain pointing to your VPS IP).
# Used by Caddy to obtain a Let's Encrypt certificate. Leave empty to skip.
WEBAPP_DOMAIN=
# Full https URL of the Mini App; when set, the bot's menu button opens it.
# Usually https://<WEBAPP_DOMAIN>
WEBAPP_URL=
